# Database (Railway provides this automatically with PostgreSQL add-on)
DATABASE_URL=postgresql+asyncpg://halalchecker:halalchecker@localhost:5433/halalchecker

# DeepSeek V3.2 API (used for LLM classification + vision OCR fallback)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# CORS — add your Vercel domain for production
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Embedding model
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Debug mode (disable in production)
DEBUG=false
